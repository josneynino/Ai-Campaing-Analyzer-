# Copie a .env y ajuste los valores.

# Base de datos SQLite (desarrollo típico)
DATABASE_URL=file:./prisma/dev.db

# JWT (en producción use un secreto largo; en desarrollo puede omitirse si el código aplica fallback)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=1d

# Google Gemini — obligatorio para que el worker genere el informe
# https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-from-google-ai-studio

# CORS: incluya el origen del frontend (Vite suele ser 5173)
FRONTEND_URL=http://localhost:5173

LOG_LEVEL=info

# Redis — cola BullMQ (obligatorio para encolar/analizar)
# Local: redis://127.0.0.1:6379
# Nube (Upstash, Redis Cloud, etc.): pegue la URL que le den el panel, p. ej. rediss://...
REDIS_URL=redis://127.0.0.1:6379

# Opcionales (APIs externas)
META_AD_LIBRARY_ACCESS_TOKEN=
META_AD_LIBRARY_ENDPOINT=
GOOGLE_ADS_TRANSPARENCY_ENDPOINT=

# En desarrollo local use: development
NODE_ENV=development
